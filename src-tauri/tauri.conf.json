{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "swarmfm",
  "version": "0.0.1",
  "identifier": "com.swarmfm.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Swarm-FM (Mini Player)",
        "width": 400,
        "height": 275,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
